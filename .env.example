# BRAPI - API gratuita de dados da B3 (https://brapi.dev)
BRAPI_KEY=seu_token_aqui

# Anthropic - Claude AI (https://console.anthropic.com)
ANTHROPIC_API_KEY=sua_chave_aqui

# Configurações do sistema
# Lista de tickers para monitorar (separados por vírgula)
WATCHLIST=PETR4,VALE3,ITUB4,BBDC4,WEGE3,MGLU3,ABEV3,RENT3

# Intervalo em segundos para o modo watch (padrão: 300 = 5 minutos)
WATCH_INTERVAL=300

# Número máximo de ações analisadas por vez
MAX_STOCKS=8
